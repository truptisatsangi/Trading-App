# Source-of-truth DB that already has canonical_events (and maybe derived tables)
DB_URL=postgres://postgres:postgres@localhost:5433/token_db

# RPC for sampling checks (optional but recommended)
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# Determinism replay window (canonical event id range to copy+replay)
REPLAY_FROM_ID=1
REPLAY_TO_ID=2000

# Sampling config (how many canonical rows to compare)
SAMPLE_SIZE=25

