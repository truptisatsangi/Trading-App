RPC_URL=https://mainnet.base.org
# Optional comma-separated RPC failover list.
RPC_URLS=
CHAIN_ID=8453
DB_URL=postgres://postgres:postgres@localhost:5432/trading_platform

# Optional: first block to start from when no checkpoint exists
START_BLOCK=0

# Number of blocks fetched per loop
BLOCK_BATCH_SIZE=500
# Max getLogs range per request; useful for free-tier RPC limits
LOG_RANGE_LIMIT=10
# Reorg replay window for future rollback/replay logic
REORG_REPLAY_WINDOW=30

# Confirmation depth to reduce reorg risk
CONFIRMATIONS=3

# Milliseconds to wait when no new finalized blocks
POLL_INTERVAL_MS=4000

# Optional override for PositionManager/AnyPositionManager addresses.
# If empty, Base mainnet addresses from PRD.md are used by default.
POSITION_MANAGER_ADDRESSES=

# Optional override for token addresses used for Transfer indexing.
# If empty, transfer logs are not indexed.
TOKEN_ADDRESSES=

# Optional override for ERC-721 ownership transfer tracking
FLAUNCH_NFT_ADDRESSES=

# Optional override for Chainlink aggregator addresses
CHAINLINK_AGGREGATOR_ADDRESSES=

# Kafka outbox relay
ENABLE_KAFKA=false
KAFKA_CLIENT_ID=indexer-service
KAFKA_BROKERS=localhost:9092
KAFKA_CANONICAL_TOPIC=canonical.events.v1
KAFKA_OUTBOX_POLL_MS=1000
KAFKA_OUTBOX_BATCH_SIZE=200

# Optional health endpoint
HEALTH_PORT=3001
