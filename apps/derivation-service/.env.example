DB_URL=postgres://postgres:postgres@localhost:5433/token_db
CHAIN_ID=8453
CHECKPOINT_NAME=derivation-v1
EVENT_BATCH_SIZE=200
POLL_INTERVAL_MS=3000
PROCESSOR_NAME=derivation-service

USE_KAFKA_PRIMARY=false
KAFKA_CLIENT_ID=derivation-service
KAFKA_GROUP_ID=derivation-v1
KAFKA_BROKERS=localhost:9092
KAFKA_CANONICAL_TOPIC=canonical.events.v1

ENABLE_KAFKA_DERIVED_PUBLISH=true
KAFKA_DERIVED_TOPIC=derived.changes.v1

ENABLE_REDIS_PUBLISH=true
REDIS_URL=redis://localhost:6379
REDIS_DERIVED_CHANNEL=derived.changes.v1
HEALTH_PORT=3002
